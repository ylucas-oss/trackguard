# TrackGuard — Configuration
# ===========================
# Copier ce fichier en .env et remplir les valeurs

# Google Service Account
# Option 1: Chemin vers le fichier JSON de credentials
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Option 2: Credentials inline (JSON encodé en base64)
# GOOGLE_CREDENTIALS_BASE64=eyJ0eXBlIjoic2VydmljZV9hY2NvdW50Ii...

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=alerts@example.com
SMTP_PASS=your-password
SMTP_FROM=TrackGuard <alerts@example.com>

# Destinataires des alertes (séparés par des virgules)
ALERT_EMAIL_TO=yannick@mv-group.fr

# Slack (optionnel — Phase 2)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# Mode dry-run (true = pas d'envoi d'alertes réelles)
DRY_RUN=true
